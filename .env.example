NODE_ENV=development
PORT=4000
WEB_ORIGIN=http://localhost:5173
API_PUBLIC_URL=http://localhost:4000
DATABASE_URL=postgresql://khan_ludo:khan_ludo@localhost:5432/khan_ludo
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_EXPIRES_IN_SECONDS=604800
COOKIE_NAME=khan_ludo_session
ADMIN_CLAIM_SECRET=replace-with-a-random-bootstrap-secret-at-least-24-characters

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# ZiniPay auto deposit (optional — synced to DB on API startup)
ZINI_PAY_API_KEY=
ZINI_PAY_BRAND_ORIGIN=https://prizejito.com
ZINI_PAY_WEBHOOK_URL=https://api.prizejito.com/api/wallet/zinipay/webhook

# Proxy count used by Express when deployed behind a trusted reverse proxy.
TRUST_PROXY=0

# Webuzo / production deploy (optional)
# WEB_ROOT=/home/nixbazar/prizejito.com
# DEPLOY_REPO_PATH=/home/nixbazar/prizejito.com
# DEPLOY_BRANCH=main
# DEPLOY_SCRIPT=/home/nixbazar/prizejito.com/scripts/update-changed.sh
# GITHUB_WEBHOOK_SECRET=generate-with-scripts/setup-github-auto-deploy.sh
# API_RESTART_MODE=webuzo
# APK_DOWNLOAD_URL=https://prizejito.com/downloads/prizejito.apk
